# ─────────────────────────────────────────────────────────────────────────
#  Coming-Soon gate (see middleware.ts)
#
#  The gate is FAIL-CLOSED in production: it is ON by default, so the public
#  sees /coming-soon while the site is built. You only ever set these in the
#  Vercel dashboard; local `pnpm dev` is never gated.
# ─────────────────────────────────────────────────────────────────────────

# Set to "false" (the exact string) to LAUNCH: lifts the gate and serves the
# real site. Any other value, or leaving it unset, keeps the gate ON.
# During construction, leave this unset (or "true") in Vercel.
COMING_SOON=false

# Secret token for the team preview bypass. Visit any URL with
# ?preview=<this-value> to browse the WIP site behind the gate; ?preview=off
# clears it. If this is empty/unset, the bypass is disabled entirely.
# Use a long random string.
COMING_SOON_BYPASS=change-me-to-a-long-random-string

# ─────────────────────────────────────────────────────────────────────────
#  Contact form delivery (see components/contact/contact-form.tsx)
#
#  The /contact form POSTs directly to Web3Forms from the browser, which
#  delivers to the inbox registered with the access key (the school's
#  sjamalinao@gmail.com) and sets reply-to to the visitor. No mailbox and no
#  DNS setup required. If the key is unset, the form degrades gracefully to a
#  plain mailto: link.
#
#  This key is PUBLIC (NEXT_PUBLIC_) by necessity: Web3Forms' free plan only
#  accepts browser-side submissions, so the key ships in the client bundle.
#  That is acceptable because (a) Web3Forms rejects non-browser requests, so a
#  scraped key can't be curl-spammed from a script, and (b) you should lock the
#  key to your domain via "Allowed Domains" in the Web3Forms dashboard.
#
#  Setup (one time): sign up at https://web3forms.com with sjamalinao@gmail.com,
#  copy the access key, paste it below (and into the Vercel dashboard), then in
#  the Web3Forms dashboard set Allowed Domains to localhost + your live domain.
# ─────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_WEB3FORMS_ACCESS_KEY=your-web3forms-access-key
