# Copy to .env.local and fill in. Never commit .env.local.
# All values below are read by the /contact form + app/api/contact route.

# --- Google Workspace SMTP (transactional email for the contact form) ---
# The /contact form sends through the school's own Google Workspace over
# authenticated SMTP. All server-side, NOT NEXT_PUBLIC. Setup:
#   1. Create a DEDICATED, low-privilege Workspace mailbox for sending only,
#      e.g. web@sjamalinao.edu.ph (do NOT reuse info@/registrar@ or an admin).
#   2. Turn on 2-Step Verification on that mailbox, then generate a Google
#      App Password (myaccount.google.com > Security > App passwords).
#   3. Put the mailbox in SMTP_USER and the 16-char App Password in SMTP_PASS.
# NOTE: an App Password grants full IMAP/SMTP access to that mailbox, so keep
# the mailbox isolated and store SMTP_PASS only in Vercel env (never committed).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=web@sjamalinao.edu.ph
SMTP_PASS=

# Display name on the notification's From. The address is always SMTP_USER
# (Google rewrites From to the authenticated mailbox); only the name is free.
CONTACT_FROM_NAME="St. Joseph's Academy"

# BCC archive inbox so no inquiry is lost if a notification is missed.
# Leave blank to disable. Skipped automatically if it equals the recipient.
CONTACT_ARCHIVE_EMAIL=info@sjamalinao.edu.ph

# --- Cloudflare Turnstile (bot protection on /api/contact) ---
# Public site key (safe to expose); rendered by the client widget.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
# Server-side secret; used by the route to verify the token.
TURNSTILE_SECRET_KEY=
# Local dev without a real widget: Cloudflare's always-pass test keys are
#   site:   1x00000000000000000000AA
#   secret: 1x0000000000000000000000000000000AA
# Or leave TURNSTILE_SECRET_KEY blank to skip verification locally (the route
# logs a warning). Never leave it blank in production.
